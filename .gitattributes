# Normalize all text files to LF in the repo AND the working tree.
# eol=lf forces LF on checkout too, so CRLF can't sneak in on Windows
# (core.autocrlf is ignored when a path matches a text attribute here).
* text=auto eol=lf

# Explicit LF for the source/text types in this project.
*.swift   text eol=lf
*.rs      text eol=lf
*.c       text eol=lf
*.h       text eol=lf
*.modulemap text eol=lf
*.toml    text eol=lf
*.lock    text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf
*.py      text eol=lf
*.applescript text eol=lf
*.svg     text eol=lf
*.pbxproj text eol=lf

# Binary assets — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.x3f  binary
*.dng  binary
*.tiff binary
*.tif  binary
*.mlmodel  binary
*.mlmodelc binary
*.mlpackage binary

# Prebuilt, extensionless executables (e.g. the x86_64-linux sd14raw decoder).
raw/dist/** binary
